{
  "extends": "@skilbjo/config-rc/tsconfig.json",
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    ".eslintrc.cjs"
  ],
  "exclude": [
    "dev-resources/repl.cjs",
    "dist",
    "node_modules"
  ],
  "compilerOptions": {
    "lib": ["DOM"],
    "paths": {
      "@src/*": [
        "./src/*"
      ],
      "@test/*": [
        "./test/*"
      ]
    },
    "types": [
      "node"
    ]
  }
}
