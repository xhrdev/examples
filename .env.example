## solver examples (Akamai/DataDome)
host=<solver-ip-or-hostname>
proxy=http://<user>:<pass>@<proxy-host>:<port>

## required only when the solver host requires an API key (e.g. gated trial access)
# solver_api_key=<issued-trial-key>

## DataDome optional installed-Chrome override (absolute executable path)
# CHROME_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
# BROWSER_HOLD_MS=30000

## EDD login
username=<edd-login-username>
password=<edd-login-password>
