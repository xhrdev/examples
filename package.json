{
  "$schema": "https://json.schemastore.org/package",
  "name": "@xhrdev/examples",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xhrdev/examples.git"
  },
  "type": "module",
  "private": true,
  "scripts": {
    "postinstall": "npx playwright install --with-deps chrome",
    "depcheck": "depcheck",
    "eslint": "eslint .",
    "exec": "node",
    "repl": "node test/repl.manual.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "node --test",
    "playwright": "NODE_EXTRA_CA_CERTS=./xhrdev.pem node src/playwright.ts",
    "puppeteer": "node src/puppeteer.ts",
    "p": "npm run playwright",
    "prepare": "husky"
  },
  "author": "XHR Software Inc",
  "dependencies": {
    "axios": "1.15.0",
    "axios-cookiejar-support": "6.0.5",
    "dotenv": "17.4.0",
    "fetch-cookie": "3.2.0",
    "http-cookie-agent": "7.0.3",
    "https-proxy-agent": "9.0.0",
    "node-fetch": "3.3.2",
    "tough-cookie": "6.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-angular": "20.5.0",
    "@skilbjo/config-rc": "1.0.46",
    "@tsconfig/node24": "24.0.4",
    "@types/node": "25.5.0",
    "@types/tough-cookie": "4.0.5",
    "cheerio": "1.2.0",
    "depcheck": "1.4.7",
    "eslint": "9.39.4",
    "husky": "9.1.7",
    "nodemon": "3.1.14",
    "playwright": "1.59.1",
    "puppeteer": "24.40.0",
    "typescript": "6.0.2",
    "undici": "7.24.7"
  },
  "imports": {
    "#src/*.js": {
      "node": "./src/*.ts",
      "import": "./dist/*.js",
      "types": "./src/*.ts"
    },
    "#test/*.js": {
      "node": "./test/*.ts"
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-angular"
    ]
  },
  "engines": {
    "node": ">=24.14.1"
  }
}
